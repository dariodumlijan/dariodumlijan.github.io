{
  "extends": "astro/tsconfigs/strict",
  "sourceMap": true,
  "inlineSources": true,
  "sourceRoot": "/",
  "compilerOptions": {
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@content/*": [
        "./src/content/*"
      ],
      "@images/*": [
        "./src/assets/images/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@pages/*": [
        "./src/pages/*"
      ],
      "@styles/*": [
        "./src/assets/styles/*"
      ]
    }
  }
}